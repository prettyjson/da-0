# The O Club Environment Variables
# Copy this to .env for local development (never commit .env!)

# Server
PORT=3001

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Coinbase CDP - Server (wallets, onramp, spend permissions)
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
CDP_WALLET_SECRET=your-cdp-wallet-secret

# Coinbase CDP - Client (embedded wallet, auth)
# VITE_ prefix exposes to frontend via Vite
VITE_CDP_PROJECT_ID=your-cdp-project-id

# Base Chain
BASE_RPC_URL=https://mainnet.base.org
USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
TREASURY_WALLET=your-treasury-wallet-address
SPEND_PERMISSION_MANAGER=0xf85210B21cC50302F477BA56686d2019dC9b67Ad

# Cloudflare Calls (Voice Rooms)
# Get from: Cloudflare Dashboard → Calls → Create App
CF_APP_ID=your-cloudflare-app-id
CF_APP_SECRET=your-cloudflare-app-secret
